<?xml version="1.0" encoding="UTF-8" standalone="no"?><uiSettingsDynamicGroupRoot>  <id>audio</id>  <version value="1"/>  <groupMetaData>    <displayName>PM_SCR_AUDIO</displayName>    <description/>    <tipText/>    <displayStyle>kSettingDisplay_StandardGroup</displayStyle>  </groupMetaData>  <Settings>    <Item type="rage__fwuiSettingsItemInfo_UInt32">      <id>sfxLevel</id>      <displayStyle>kSettingDisplay_Slider</displayStyle>      <displayName>MO_SFX</displayName>      <description>SETTING_DESC_SFX</description>      <profileStatId>AudioSfxLevel</profileStatId>      <tipText/>	  <maximum value="100"/>	  <minimum value="0"/>      <default value="10"/>      <flags>kSettingFlags_SyncToProfile</flags>    </Item>    <Item type="rage__fwuiSettingsItemInfo_UInt32">      <id>musicLevel</id>      <displayStyle>kSettingDisplay_Slider</displayStyle>      <displayName>MO_MUS</displayName>      <description>SETTING_DESC_MUSIC</description>      <profileStatId>AudioMusicLevel</profileStatId>      <tipText/>	  <maximum value="100"/>	  <minimum value="0"/>      <default value="10"/>      <flags>kSettingFlags_SyncToProfile</flags>      <dependencyConditions>        <Item>          <condition type="uiConditionNot">            <Condition type="uiConditionNetworkInMP"/>          </condition>          <displayType>kSettingDependency_Hide</displayType>        </Item>      </dependencyConditions>    </Item>    <Item type="rage__fwuiSettingsItemInfo_UInt32">      <id>musicLevelMP</id>      <displayStyle>kSettingDisplay_Slider</displayStyle>      <displayName>MO_MUS</displayName>      <description>SETTING_DESC_MUSIC</description>      <profileStatId>AudioMusicLevelMP</profileStatId>      <tipText/>	  <maximum value="100"/>	  <minimum value="0"/>      <default value="10"/>      <flags>kSettingFlags_SyncToProfile</flags>      <dependencyConditions>        <Item>          <condition type="uiConditionNetworkInMP"/>          <displayType>kSettingDependency_Hide</displayType>        </Item>      </dependencyConditions>    </Item>    <Item type="rage__fwuiSettingsItemInfo_UInt32">      <id>dialogeLevel</id>      <displayStyle>kSettingDisplay_Slider</displayStyle>      <displayName>MO_DBOOST</displayName>      <description>SETTING_DESC_DIALOGUE</description>      <profileStatId>AudioDialogeLevel</profileStatId>      <tipText/>	  <maximum value="100"/>	  <minimum value="0"/>      <default value="5"/>      <flags>kSettingFlags_SyncToProfile</flags>    </Item>    <Item type="rage__fwuiSettingsItemInfo_Bool">      <id>voiceOutput</id>      <displayStyle>kSettingDisplay_DontShow</displayStyle>      <displayName>MO_VOUT</displayName>      <description/>      <profileStatId>AudioVoiceOutput</profileStatId>      <tipText/>      <default value="true"/>      <flags>kSettingFlags_SyncToProfile</flags>    </Item>    <Item type="rage__fwuiSettingsItemInfo_Bool">      <id>gpsSpeech</id>      <displayStyle>kSettingDisplay_DontShow</displayStyle>      <displayName>MO_GPS_SPEACH</displayName>      <description/>      <profileStatId>AudioGpsSpeech</profileStatId>      <tipText/>      <default value="true"/>      <displayConverter>pause/settings/gps_speech</displayConverter>    </Item>    <Item type="rage__fwuiSettingsItemInfo_UInt32">      <id>speakerOutput</id>      <displayStyle>kSettingDisplay_Stepper</displayStyle>      <displayName>MO_OUTP</displayName>      <description>SETTING_DESC_SPEAKER_OUTPUT</description>      <profileStatId>AudioSpeakerOutput</profileStatId>      <tipText/>      <minEvaluator type="uiAudioOutputMinEvaluator"/>      <maxEvaluator type="uiAudioOutputMaxEvaluator"/>      <defaultEvaluator type="uiSettingsDefaultSpeakerOutput"/>      <infoBox>info_box_audio_config</infoBox>      <displayConverter>pause/settings/speaker_output</displayConverter>      <dependencyConditions/>    </Item>    <Item type="rage__fwuiSettingsItemInfo_UInt32">      <id>frontSpeaker</id>      <displayStyle>kSettingDisplay_Stepper</displayStyle>      <displayName>MO_SS_FRONT</displayName>      <description>SETTING_DESC_FRONT_SPEAKERS</description>      <profileStatId>AudioFrontSpeaker</profileStatId>      <tipText>SETTING_TIP_FRONT_SPEAKERS</tipText>      <maximum value="2"/>      <default value="1"/>      <infoBox>info_box_audio_config</infoBox>      <displayConverter>pause/settings/speakers_front</displayConverter>      <dependencyConditions>        <Item>          <condition type="rage__fwuiSettingsDependency_UInt32">            <setting>              <Path>audio.speakerOutput</Path>            </setting>            <action>kSettingDependency_Equal</action>            <targetValue value="3"/>          </condition>          <displayType>kSettingDependency_Hide</displayType>        </Item>      </dependencyConditions>    </Item>    <Item type="rage__fwuiSettingsItemInfo_UInt32">      <id>rearSpeaker</id>      <displayStyle>kSettingDisplay_Stepper</displayStyle>      <displayName>MO_SS_REAR</displayName>      <description>SETTING_DESC_REAR_SPEAKERS</description>      <profileStatId>AudioRearSpeaker</profileStatId>      <tipText/>      <maximum value="2"/>      <default value="1"/>      <infoBox>info_box_audio_config</infoBox>      <displayConverter>pause/settings/speakers_rear</displayConverter>      <dependencyConditions>        <Item>          <condition type="rage__fwuiSettingsDependency_UInt32">            <setting>              <Path>audio.speakerOutput</Path>            </setting>            <action>kSettingDependency_Equal</action>            <targetValue value="3"/>          </condition>          <displayType>kSettingDependency_Hide</displayType>        </Item>      </dependencyConditions>    </Item>    <Item type="rage__fwuiSettingsItemInfo_UInt32">      <id>dynamicRangeTV</id>      <displayStyle>kSettingDisplay_Stepper</displayStyle>      <displayName>MO_DYNRANGE</displayName>      <description>SETTING_DESC_DYNAMIC_RANGE</description>      <profileStatId>AudioDynamicRangeTV</profileStatId>      <tipText>SETTING_TIP_DYNAMIC_RANGE</tipText>      <maximum value="1"/>      <default value="1"/>      <displayConverter>pause/settings/dynamic_range</displayConverter>      <dependencyConditions>        <Item>          <condition type="rage__fwuiSettingsDependency_UInt32">            <setting>              <Path>audio.speakerOutput</Path>            </setting>            <action>kSettingDependency_Equal</action>            <targetValue value="0"/>          </condition>          <displayType>kSettingDependency_Hide</displayType>        </Item>      </dependencyConditions>    </Item>    <Item type="rage__fwuiSettingsItemInfo_UInt32">      <id>dynamicRangeStereo</id>      <displayStyle>kSettingDisplay_Stepper</displayStyle>      <displayName>MO_DYNRANGE</displayName>      <description>SETTING_DESC_DYNAMIC_RANGE</description>      <profileStatId>AudioDynamicRangeStereo</profileStatId>      <tipText>SETTING_TIP_DYNAMIC_RANGE</tipText>      <maximum value="1"/>      <default value="1"/>      <displayConverter>pause/settings/dynamic_range</displayConverter>      <dependencyConditions>        <Item>          <condition type="rage__fwuiSettingsDependency_UInt32">            <setting>              <Path>audio.speakerOutput</Path>            </setting>            <action>kSettingDependency_Equal</action>            <targetValue value="3"/>          </condition>          <displayType>kSettingDependency_Hide</displayType>        </Item>      </dependencyConditions>    </Item>    <Item type="rage__fwuiSettingsItemInfo_UInt32">      <id>dynamicRangeSurround</id>      <displayStyle>kSettingDisplay_Stepper</displayStyle>      <displayName>MO_DYNRANGE</displayName>      <description>SETTING_DESC_DYNAMIC_RANGE</description>      <profileStatId>AudioDynamicRangeSurround</profileStatId>      <tipText>SETTING_TIP_DYNAMIC_RANGE</tipText>      <maximum value="1"/>      <default value="1"/>      <displayConverter>pause/settings/dynamic_range</displayConverter>      <dependencyConditions>        <Item>          <condition type="rage__fwuiSettingsDependency_UInt32">            <setting>              <Path>audio.speakerOutput</Path>            </setting>            <action>kSettingDependency_Equal</action>            <targetValue value="1"/>          </condition>          <displayType>kSettingDependency_Hide</displayType>        </Item>      </dependencyConditions>    </Item>    <Item type="rage__fwuiSettingsItemInfo_UInt32">      <id>dynamicRangeHeadphones</id>      <displayStyle>kSettingDisplay_Stepper</displayStyle>      <displayName>MO_DYNRANGE</displayName>      <description>SETTING_DESC_DYNAMIC_RANGE</description>      <profileStatId>AudioDynamicRangeHeadphones</profileStatId>      <tipText>SETTING_TIP_DYNAMIC_RANGE</tipText>      <maximum value="1"/>      <default value="1"/>      <displayConverter>pause/settings/dynamic_range</displayConverter>      <dependencyConditions>        <Item>          <condition type="rage__fwuiSettingsDependency_UInt32">            <setting>              <Path>audio.speakerOutput</Path>            </setting>            <action>kSettingDependency_Equal</action>            <targetValue value="2"/>          </condition>          <displayType>kSettingDependency_Hide</displayType>        </Item>      </dependencyConditions>    </Item>    <Item type="rage__fwuiSettingsItemInfo_Bool">      <id>interactiveMusic</id>      <displayStyle>kSettingDisplay_Stepper</displayStyle>      <displayName>MO_INT_MUSIC</displayName>      <description/>      <profileStatId>AudioInteractiveMusic</profileStatId>      <tipText/>      <default value="true"/>    </Item>    <Item type="rage__fwuiSettingsItemInfo_Int32">      <id>radioStation</id>      <displayStyle>kSettingDisplay_DontShow</displayStyle>      <displayName>MO_RADIO</displayName>      <description/>      <profileStatId>AudioRadioStation</profileStatId>      <tipText/>    </Item>    <Item type="rage__fwuiSettingsItemInfo_Bool">      <id>pulseHeadset</id>      <displayStyle>kSettingDisplay_Stepper</displayStyle>      <displayName>MO_PULSE_HEADSET</displayName>      <description/>      <profileStatId>AudioPulseHeadset</profileStatId>      <tipText/>	  <default value="false"/>      <flags>kSettingFlags_SyncToProfile</flags>	  <dependencyConditions>        <Item>          <condition type="rage__fwuiSettingsDependency_UInt32">            <setting>              <Path>audio.speakerOutput</Path>            </setting>            <action>kSettingDependency_Equal</action>            <targetValue value="2"/>          </condition>          <displayType>kSettingDependency_Hide</displayType>        </Item>      </dependencyConditions>    </Item>    <Item platform="x64" type="rage__fwuiSettingsItemInfo_UInt32">      <id>latency</id>      <displayStyle>kSettingDisplay_Slider</displayStyle>      <flags>kSettingFlags_SyncToProfile</flags>      <displayName>MO_AUDIO_LATENCY</displayName>      <description>SETTING_DESC_AUDIO_LATENCY</description>      <profileStatId>AudioLatencyLevel</profileStatId>      <tipText/>      <default value="0"/>      <maximum value="9"/>    </Item>  </Settings>  <SubGroups>    <Item type="uiSettingsDynamicSubGroup">      <id>voice</id>      <groupMetaData>        <displayName>MO_VOUT</displayName>        <description/>        <tipText/>        <displayStyle>kSettingDisplay_StandardGroup</displayStyle>        <dependencyConditions>          <Item>            <condition type="uiConditionIsMultiplayerUnlocked"/>            <displayType>kSettingDependency_Hide</displayType>          </Item>        </dependencyConditions>      </groupMetaData>      <Settings>        <Item type="rage__fwuiSettingsItemInfo_Bool">          <id>voiceEnabled</id>          <displayStyle>kSettingDisplay_Stepper</displayStyle>          <displayName>MO_VOICE_ENABLE</displayName>          <description>SETTING_DESC_VOICE_CHAT</description>          <profileStatId>AudioVoiceEnabled</profileStatId>          <tipText/>          <defaultEvaluator type="uiSettingsDefaultVoiceChatEnable"/>          <flags>kSettingFlags_SyncToProfile</flags>          <dependencyConditions>            <Item>              <condition type="uiConditionHasChatPrivileges"/>              <displayType>kSettingDependency_Disable</displayType>            </Item>          </dependencyConditions>        </Item>        <Item platform="x64" type="rage__fwuiSettingsItemInfo_UInt32">          <id>outputDevice</id>          <displayStyle>kSettingDisplay_Stepper_Raw</displayStyle>          <displayName>MO_OUTP_DVC</displayName>          <description>SETTING_DESC_AUDIO_OUTPUT_DEVICE</description>          <profileStatId>AudioVoiceOutputDevice</profileStatId>          <tipText/>          <maxEvaluator type="uiVoiceOutputDeviceMaxEvaluator"/>          <displayConverter>pause/settings/voice_output</displayConverter>          <dependencyConditions>            <Item>              <condition type="rage__fwuiSettingsDependency_Bool">                <setting>                  <Path>audio.voice.voiceEnabled</Path>                </setting>                <action>kSettingDependency_Equal</action>                <targetValue value="true"/>              </condition>              <displayType>kSettingDependency_Disable</displayType>            </Item>          </dependencyConditions>        </Item>        <Item platform="x64" type="rage__fwuiSettingsItemInfo_UInt32">          <id>outputDeviceId</id>          <displayStyle>kSettingDisplay_DontShow</displayStyle>          <maximum value="-1"/>        </Item>        <Item platform="x64|linux" type="rage__fwuiSettingsItemInfo_UInt32">          <id>volume</id>          <displayStyle>kSettingDisplay_Slider</displayStyle>          <flags>kSettingFlags_SyncToProfile</flags>          <displayName>MO_CHAT_OVOL</displayName>          <description>SETTING_DESC_CHAT_LEVEL</description>          <profileStatId>AudioVoiceVolume</profileStatId>          <tipText/>          <default value="10"/>          <dependencyConditions>            <Item>              <condition type="rage__fwuiSettingsDependency_Bool">                <setting>                  <Path>audio.voice.voiceEnabled</Path>                </setting>                <action>kSettingDependency_Equal</action>                <targetValue value="true"/>              </condition>              <displayType>kSettingDependency_Disable</displayType>            </Item>          </dependencyConditions>        </Item>        <Item platform="x64|linux" type="rage__fwuiSettingsItemInfo_Bool">          <id>talkEnabled</id>          <displayStyle>kSettingDisplay_Stepper</displayStyle>          <flags>kSettingFlags_SyncToProfile</flags>          <displayName>MO_TLK_ENABLE</displayName>          <description>MO_TLK_ENABLE_DESC</description>          <profileStatId>AudioVoiceTalkEnabled</profileStatId>          <tipText/>          <default value="true"/>          <dependencyConditions>            <Item>              <condition type="rage__fwuiSettingsDependency_Bool">                <setting>                  <Path>audio.voice.voiceEnabled</Path>                </setting>                <action>kSettingDependency_Equal</action>                <targetValue value="true"/>              </condition>              <displayType>kSettingDependency_Disable</displayType>            </Item>          </dependencyConditions>        </Item>        <Item platform="x64" type="rage__fwuiSettingsItemInfo_UInt32">          <id>inputDevice</id>          <displayStyle>kSettingDisplay_Stepper_Raw</displayStyle>          <displayName>MO_INPUT_DVC</displayName>          <description>SETTING_DESC_AUDIO_INPUT_DEVICE</description>          <profileStatId>AudioVoiceInputDevice</profileStatId>          <tipText/>          <maxEvaluator type="uiVoiceInputDeviceMaxEvaluator"/>          <displayConverter>pause/settings/voice_input</displayConverter>          <dependencyConditions>            <Item>              <condition type="uiConditionAnd">                <Conditions>                  <Item type="rage__fwuiSettingsDependency_Bool">                    <setting>                      <Path>audio.voice.voiceEnabled</Path>                    </setting>                    <action>kSettingDependency_Equal</action>                    <targetValue value="true"/>                  </Item>                  <Item type="rage__fwuiSettingsDependency_Bool">                    <setting>                      <Path>audio.voice.talkEnabled</Path>                    </setting>                    <action>kSettingDependency_Equal</action>                    <targetValue value="true"/>                  </Item>                </Conditions>              </condition>              <displayType>kSettingDependency_Disable</displayType>            </Item>          </dependencyConditions>        </Item>        <Item platform="x64" type="rage__fwuiSettingsItemInfo_UInt32">          <id>inputDeviceId</id>          <displayStyle>kSettingDisplay_DontShow</displayStyle>          <maximum value="-1"/>        </Item>        <Item platform="x64|linux" type="rage__fwuiSettingsItemInfo_UInt32">          <id>chatMode</id>          <displayStyle>kSettingDisplay_Stepper</displayStyle>          <flags>kSettingFlags_SyncToProfile</flags>          <displayName>MO_VCHAT_MODE</displayName>          <description>SETTING_DESC_VOICE_CHAT_MODE</description>          <profileStatId>AudioVoiceChatMode</profileStatId>          <tipText/>          <maximum value="1"/>          <default value="1"/>          <displayConverter>pause/settings/voice_chat_mode</displayConverter>          <dependencyConditions>            <Item>              <condition type="uiConditionAnd">                <Conditions>                  <Item type="rage__fwuiSettingsDependency_Bool">                    <setting>                      <Path>audio.voice.voiceEnabled</Path>                    </setting>                    <action>kSettingDependency_Equal</action>                    <targetValue value="true"/>                  </Item>                  <Item type="rage__fwuiSettingsDependency_Bool">                    <setting>                      <Path>audio.voice.talkEnabled</Path>                    </setting>                    <action>kSettingDependency_Equal</action>                    <targetValue value="true"/>                  </Item>                </Conditions>              </condition>              <displayType>kSettingDependency_Disable</displayType>            </Item>          </dependencyConditions>        </Item>        <Item platform="x64|linux" type="rage__fwuiSettingsItemInfo_UInt32">          <id>micVolume</id>          <displayStyle>kSettingDisplay_Slider</displayStyle>          <flags>kSettingFlags_SyncToProfile</flags>          <displayName>MO_MIC_VOL</displayName>          <description>SETTING_DESC_MIC_VOLUME</description>          <profileStatId>AudioVoiceMicVolume</profileStatId>          <tipText>SETTING_TIP_MIC_VOLUME</tipText>          <default value="10"/>          <dependencyConditions>            <Item>              <condition type="uiConditionAnd">                <Conditions>                  <Item type="rage__fwuiSettingsDependency_Bool">                    <setting>                      <Path>audio.voice.voiceEnabled</Path>                    </setting>                    <action>kSettingDependency_Equal</action>                    <targetValue value="true"/>                  </Item>                  <Item type="rage__fwuiSettingsDependency_Bool">                    <setting>                      <Path>audio.voice.talkEnabled</Path>                    </setting>                    <action>kSettingDependency_Equal</action>                    <targetValue value="true"/>                  </Item>                </Conditions>              </condition>              <displayType>kSettingDependency_Disable</displayType>            </Item>          </dependencyConditions>        </Item>        <Item platform="x64|linux" type="rage__fwuiSettingsItemInfo_UInt32">          <id>micSensitivity</id>          <displayStyle>kSettingDisplay_Slider</displayStyle>          <flags>kSettingFlags_SyncToProfile</flags>          <displayName>MO_MIC_SEN</displayName>          <description>SETTING_DESC_MIC_SENSITIVITY</description>          <profileStatId>AudioVoiceMicSensitivity</profileStatId>          <tipText>SETTING_TIP_MIC_SENSITIVITY</tipText>          <default value="10"/>          <dependencyConditions>            <Item>              <condition type="uiConditionAnd">                <Conditions>                  <Item type="rage__fwuiSettingsDependency_Bool">                    <setting>                      <Path>audio.voice.voiceEnabled</Path>                    </setting>                    <action>kSettingDependency_Equal</action>                    <targetValue value="true"/>                  </Item>                  <Item type="rage__fwuiSettingsDependency_Bool">                    <setting>                      <Path>audio.voice.talkEnabled</Path>                    </setting>                    <action>kSettingDependency_Equal</action>                    <targetValue value="true"/>                  </Item>                  <Item type="rage__fwuiSettingsDependency_UInt32">                    <setting>                      <Path>audio.voice.chatMode</Path>                    </setting>                    <action>kSettingDependency_Equal</action>                    <targetValue value="0"/>                  </Item>                </Conditions>              </condition>              <displayType>kSettingDependency_Disable</displayType>            </Item>          </dependencyConditions>        </Item>      </Settings>    </Item>  </SubGroups></uiSettingsDynamicGroupRoot>